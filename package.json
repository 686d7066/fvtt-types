{
  "name": "fvtt-types",
  "version": "14.363.0",
  "description": "Unofficial TypeScript declarations generated from a local Foundry Virtual Tabletop installation. Not affiliated with Foundry Gaming LLC.",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "build": "npm run generate && npm run sync:dependencies",
    "generate": "tsx scripts/generate-types.ts",
    "sync:dependencies": "tsx scripts/sync-dependencies.ts",
    "test:consumer": "tsc --noEmit -p test/tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "foundry-vtt",
    "foundryvtt",
    "typescript",
    "types"
  ],
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsx": "^4.22.3",
    "typescript": "5.6.3"
  },
