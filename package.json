    "eslint-linter-browserify": "^10.2.1",
    "handlebars": "^4.7.9",
    "handlebars-intl": "^1.1.2",
    "jquery": "^3.7.1",
    "pixi.js": "7.4.3",
    "prosemirror-collab": "^1.3.1",
